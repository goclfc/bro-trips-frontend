# Optional. If unset, the Google sign-in button is hidden and only
# email+password works.
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Optional. If unset, requests go to /api (same-origin; works in dev via the
# Vite proxy). Set to the backend URL for different-origin deployments.
# VITE_API_URL=https://api.your-host.example
